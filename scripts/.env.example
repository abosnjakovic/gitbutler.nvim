# Local-only environment variables for release-tooling scripts.
# Copy this file to scripts/.env (gitignored) and fill in real values.
#
# release-please runs server-side via GitHub Actions and uses
# secrets.GITHUB_TOKEN (auto-provided). Nothing in this file is required for
# the actual release pipeline — it exists for future local helpers and to
# document the contract for contributors.

# GitHub CLI auth is recommended for `make check-env` and any local gh
# commands. Run `gh auth login` instead of putting a token here.
# GH_TOKEN=
